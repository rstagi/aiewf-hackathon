# SIA Cloud — env.
#
# Storage is Mongo-behind-an-interface with a demo-safe fallback (PLAN risk #1):
#   • MONGO_URI set + reachable        → MongoDB backend
#   • MONGO_URI unset OR Mongo down    → file store at data/runtime/registry/ (gitignored)
# So the Cloud boots with ZERO env and never dies on a DB connection error.
#
# MONGO_URI=mongodb://localhost:27017
# MONGO_DB=sia

# Optional inbound shared key for the mutation/ingest routes. Unset ⇒ auth disabled.
# SIA_API_KEY=
